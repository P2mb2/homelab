{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["https://openclaw.burro-iguana.ts.net"],
      "allowInsecureAuth": true
    }
  },
  "memory": {
    "backend": "qmd"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": [737263887],
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "github-copilot/claude-sonnet-4.5",
        "fallbacks": [
          "github-copilot/gemini-3-flash",
          "github-copilot/gpt-5-mini"
        ]
      },
      "models": {
        "github-copilot/claude-sonnet-4.5": { "alias": "normal" },
        "github-copilot/gemini-3-flash": { "alias": "barato" },
        "github-copilot/gpt-5-mini": { "alias": "gratis" },
        "github-copilot/claude-opus-4.6": { "alias": "caro" }
      },
      "heartbeat": {
        "every": "30m",
        "model": "github-copilot/gpt-5-mini",
        "target": "last"
      },
      "subagents": {
        "model": "github-copilot/gemini-3-flash",
        "maxConcurrent": 1,
        "archiveAfterMinutes": 60
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m"
      },
      "compaction": {
        "reserveTokensFloor": 40000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000,
          "systemPrompt": "Session nearing compaction. Store durable memories now.",
          "prompt": "Write any lasting notes to memory/YYYY-MM-DD.md; reply with NO_REPLY if nothing to store."
        }
      },
      "contextTokens": 200000
    }
  },  
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "enabled": true,
        "provider": "gemini",
        "gemini": {
          "apiKey": "${GEMINI_SEARCH_PROVIDER_API_KEY}"
        }
      }
    }
  }
}
